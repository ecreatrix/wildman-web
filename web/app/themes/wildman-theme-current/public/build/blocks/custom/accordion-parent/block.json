{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wa/accordion-parent",
	"title": "Accordion",
	"category": "common",
	"description": "Allow accordion style hiding of content.",
	"textdomain": "default",
	"keywords": [ "wa"],
	"attributes": {
		"anchor": {
			"type": "string"
		},
		"allowMultipleOpen": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"anchor": true,
		"align": true,
		"color": {
			"text": false,
			"background": false
		}
	},
	"styles": [
		{
			"name": "default",
			"label": "Default",
			"isDefault": true
		},
		{ "name": "rounded", "label": "Rounded" }
	],
	"editorStyle": "wa-block-accordion-parent-editor",
	"style": "wa-block-accordion-parent"
}
