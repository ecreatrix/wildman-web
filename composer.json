{
 "name": "with-alyx/wildman",
  "type": "project",
  "license": "MIT",
  "description": "WordPress with Sage and Bedrock",
  "homepage": "https://withalyx.ca",
  "authors": [
    {
      "name": "Alyx Calder",
      "email": "alyxcalder@gmail.com"
    }
  ],
  "keywords": [
    "bedrock", "composer", "roots", "wordpress", "wp", "wp-config"
  ],
  "support": {
    "issues": "https://github.com/roots/bedrock/issues",
    "forum": "https://discourse.roots.io/category/bedrock"
  },
  "repositories": [
    {
      "name": "wp-packages",
      "type": "composer",
      "url": "https://repo.wp-packages.org",
      "only": [
        "wp-plugin/*",
        "wp-theme/*"
      ]
    }
  ],
  "require": {
    "php": ">=8.1",
    "composer/installers": "^2.2",
    "vlucas/phpdotenv": "^5.5",
    "oscarotero/env": "^2.1",
    "filp/whoops": "^2.18",
    "roots/acorn": "^5.0",
    "roots/acorn-fse-helper": "^1.0",
    "roots/bedrock-autoloader": "^1.0",
    "roots/bedrock-disallow-indexing": "^2.0",
    "roots/wordpress": "*",
    "roots/wp-config": "1.0.0",
    "roots/wp-password-bcrypt": "1.2.0",
    "wp-plugin/google-site-kit": "^1.175",
    "wp-plugin/svg-support": "^2.5",
    "wp-plugin/wp-mail-smtp": "^4.7",
    "wp-plugin/jetpack": "^15.6",
    "wp-plugin/force-regenerate-thumbnails": "^2.2",
    "wp-plugin/jetpack": "^15.6",
    "wp-plugin/wp-smushit": "^3.24",
    "wp-plugin/wordpress-seo": "^27.3",
    "wp-plugin/google-analytics-for-wordpress": "^10.1",
    "wp-theme/twentytwentyfive": "^1.1",
    "wp-plugin/create-block-theme": "^2.6",
  	"wp-plugin/font-awesome": "^5.1"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "installer-paths": {
      "web/app/mu-plugins/{$name}/": ["type:wordpress-muplugin"],
      "web/app/plugins/{$name}/": ["type:wordpress-plugin"],
      "web/app/themes/{$name}/": ["type:wordpress-theme"]
    },
    "wordpress-install-dir": "web/wp"
  },
  "scripts": {
    "lint": "pint --test",
    "lint:fix": "pint"
  }
}
